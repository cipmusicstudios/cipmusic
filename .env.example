# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase（Auth / 数据库）。在项目根目录创建 `.env.local`（已 gitignore），填入控制台「Project URL」与 anon public key。
# 仅使用 anon key，勿将 service_role 写入前端。修改后请重启 `npm run dev` / `vite preview`。
# VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
# VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Guest auth (游客「立即注册」「登录」按钮；不配则仅 Dev Preview 下保留本地切 tier 行为)
# VITE_AUTH_SIGNUP_URL="https://example.com/signup"
# VITE_AUTH_LOGIN_URL="https://example.com/login"

# Authing Guard（跳转托管登录 startWithRedirect；游客 Sign Up / Log In 走此流程）
# VITE_AUTHING_APP_ID="你的应用 ID"
# 必填：与控制台「应用域名」一致，否则 getPublicConfig 易 Failed to fetch（勿漏协议、勿多末尾斜杠）
# VITE_AUTHING_APP_HOST="https://你的租户.authing.cn"
# 须与 Authing 控制台「登录回调 URL」及本机 dev 端口一致（默认 npm run dev 为 3001）
# VITE_AUTHING_REDIRECT_URI="http://localhost:3001/"
# 可选：Guard 语言 zh-CN / en-US
# VITE_AUTHING_LANG="zh-CN"
# 可选：登出后回到的地址
# VITE_AUTHING_LOGOUT_REDIRECT_URI="http://localhost:3001/"

# Cloudflare R2 private premium scenes.
# 生产建议：premium scenes 使用单独 private bucket（free scenes 可继续留在 public bucket），
# 不绑定 `r2.dev` public domain / custom domain；浏览器和未来 App 都只通过 broker 获取 presigned GET URL。
# R2 bucket CORS 至少允许你的站点/App origin 对 GET, HEAD 发起跨域请求，因为 <video src> 会直连 presigned URL。
# CF_R2_ACCOUNT_ID=""
# CF_R2_ACCESS_KEY_ID=""
# CF_R2_SECRET_ACCESS_KEY=""
# CF_R2_BUCKET="aurasounds-premium-scenes"
# 可选：private object 前缀；当前约定 key 为 premium-scenes/forest.mp4 / premium-scenes/starry.mp4
# CF_R2_SCENE_PREFIX="premium-scenes"
# 可选：scene presigned URL TTL（秒）。背景视频建议 1800~7200，避免播放中 seek / 重缓冲撞过期。
# CF_R2_SCENE_EXPIRES_SECONDS="3600"

# Optional: Spotify Web API (Client Credentials). Create a local `.env` (gitignored).
# Used by:
# - `npm run artist-images:fetch` (artist portraits)
# - `npm run generate:official-metadata` (track **album cover** art — preferred over Apple when set)
# SPOTIFY_CLIENT_ID=""
# SPOTIFY_CLIENT_SECRET=""
#
# Cover/metadata script (429-safe, batched Search):
# - Default: Spotify Search only for slugs in tmp/cover-categories.json (run `npm run audit:cover-categories`), max 50/run (SPOTIFY_PRIORITY_LIMIT).
# - SPOTIFY_SEARCH_ALL=1 — search every track (heavy; not recommended when rate-limited).
# - SPOTIFY_REQUEST_GAP_MS — min gap between Web API calls (default 2200).
# - SPOTIFY_SEARCH_INTER_QUERY_MS — extra gap between Search queries for one song (default 1400).
# - SPOTIFY_PREFLIGHT=1 — recommended: one-shot Search probe first; if 429, script exits without rewriting local-import-official-metadata.generated.ts.
# - SPOTIFY_429_MAX_WAIT_MS — cap wait before a single 429 retry (default 90000). Set 0 to skip wait/retry and open circuit immediately (no hour-long shell hang).
# - Start with a small SPOTIFY_PRIORITY_LIMIT (e.g. 20–40), then raise once stable.
#
# CIP YouTube link script (`npm run generate:cip-links`):
# - CIP_LINKS_MODE=risk (default) — two-step strict match; re-binds every **high-risk** slug even if a URL existed, plus any seed still missing a watch URL. Not a blind 545 scan.
# - CIP_LINKS_MODE=all — legacy: only seeds that still have **no** watch URL (plus disambiguation / manual link overrides). Does **not** re-validate existing channel matches.
# - CIP_MIN_POOL_SCORE / CIP_SHORT_TITLE_MIN_SCORE / CIP_NO_ARTIST_MIN_SCORE — tighten or loosen strict two-step match.
# - CIP_PREV_SNAPSHOT_REF=<git ref> — optional: merge watch URLs from `git show <ref>:src/local-import-cip-links.generated.ts` into the current file **only where the current row has no watch URL** (e.g. recover pre-strip links before re-running strict resolve + suspect tier).
# Optional: tmp/cip-high-risk-extra.json as `{ "slugs": ["slug-a", "slug-b"] }` to force-review manual mis-bindings.
